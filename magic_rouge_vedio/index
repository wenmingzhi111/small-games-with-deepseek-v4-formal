  haste:     { name: '疾风之靴', icon: '👢', desc: '移动速度 +12%（可叠加）。',              apply: s => s.speedMult += 0.12 },
  focus:     { name: '奥术核心', icon: '🔮', desc: '所有技能法力消耗 -15%（可叠加，最低 20%）。', apply: s => s.manaDiscount = Math.min(0.8, s.manaDiscount + 0.15) },
