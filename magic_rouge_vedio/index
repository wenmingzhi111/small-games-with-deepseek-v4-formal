  /* ---------------- Three.js 场景初始化 ---------------- */
  initThree() {
    this.scene = new THREE.Scene();
    this.scene.background = new THREE.Color(0x0a0618);
    this.scene.fog = new THREE.FogExp2(0x1a0f33, 0.018);   // 体积雾感

    this.camera = new THREE.PerspectiveCamera(60, innerWidth / innerHeight, 0.1, 500);

    this.renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: 'high-performance' });
    this.renderer.setSize(innerWidth, innerHeight);
    this.renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    this.renderer.shadowMap.enabled = true;
    this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    this.renderer.toneMapping = THREE.ACESFilmicToneMapping;
    this.renderer.toneMappingExposure = 1.0;
    document.body.appendChild(this.renderer.domElement);

    // ---- 灯光 ----
    // 环境光（受亮度滑块控制）
    this.ambient = new THREE.AmbientLight(0x4a3a7a, 0.6);
    this.scene.add(this.ambient);

    // 半球光提供柔和的上下补光
    this.hemi = new THREE.HemisphereLight(0x6a5aff, 0x1a0f33, 0.5);
    this.scene.add(this.hemi);

    // 主方向光（月光感），投射阴影
    this.moon = new THREE.DirectionalLight(0x9a8aff, 0.7);
    this.moon.position.set(20, 40, 15);
    this.moon.castShadow = true;
    this.moon.shadow.mapSize.set(2048, 2048);
    this.moon.shadow.camera.near = 1;
    this.moon.shadow.camera.far = 120;
    const sc = 60;
    this.moon.shadow.camera.left = -sc; this.moon.shadow.camera.right = sc;
    this.moon.shadow.camera.top = sc; this.moon.shadow.camera.bottom = -sc;
    this.moon.shadow.bias = -0.0004;
    this.scene.add(this.moon);

    this.brightnessMult = 1.0;   // 由滑块设置
  }

  /* ---------------- 构建远古圣所场景 ---------------- */
  buildSanctuary() {
    const rng = (a, b) => a + Math.random() * (b - a);

    // ---- 地面 ----
    const groundGeo = new THREE.CircleGeometry(ARENA_RADIUS + 6, 64);
    const groundMat = new THREE.MeshStandardMaterial({ color: 0x241a3a, roughness: 0.95, metalness: 0.1 });
    const ground = new THREE.Mesh(groundGeo, groundMat);
    ground.rotation.x = -Math.PI / 2;
    ground.receiveShadow = true;
    this.scene.add(ground);

    // 地面上的发光魔法符文圈
    const runeGeo = new THREE.RingGeometry(ARENA_RADIUS - 2, ARENA_RADIUS - 1.4, 96);
    const runeMat = new THREE.MeshBasicMaterial({ color: 0x7a5aff, transparent: true, opacity: 0.35, side: THREE.DoubleSide });
    const rune = new THREE.Mesh(runeGeo, runeMat);
    rune.rotation.x = -Math.PI / 2; rune.position.y = 0.02;
    this.scene.add(rune);
    const rune2 = new THREE.Mesh(new THREE.RingGeometry(6, 6.4, 64), runeMat.clone());
    rune2.rotation.x = -Math.PI / 2; rune2.position.y = 0.02;
    this.scene.add(rune2);

    // ---- 破碎的石柱（围绕竞技场散布）----
    const pillarMat = new THREE.MeshStandardMaterial({ color: 0x3a3050, roughness: 0.9 });
    const pillarCount = 16;
    for (let i = 0; i < pillarCount; i++) {
      const ang = (i / pillarCount) * Math.PI * 2 + rng(-0.15, 0.15);
      const r = ARENA_RADIUS - rng(2, 8);
      const h = rng(4, 11);
      const geo = new THREE.CylinderGeometry(rng(0.8, 1.2), rng(1.0, 1.5), h, 8);
      const p = new THREE.Mesh(geo, pillarMat);
      p.position.set(Math.cos(ang) * r, h / 2 - rng(0, 1.5), Math.sin(ang) * r);
      p.rotation.z = rng(-0.08, 0.08);
      p.castShadow = true; p.receiveShadow = true;
      this.scene.add(p);
      // 部分柱子顶部有碎块
      if (Math.random() > 0.5) {
        const cap = new THREE.Mesh(new THREE.BoxGeometry(rng(1.6,2.4), rng(0.6,1), rng(1.6,2.4)), pillarMat);
        cap.position.set(p.position.x + rng(-0.5,0.5), h + rng(-1,0.3), p.position.z + rng(-0.5,0.5));
        cap.rotation.set(rng(0,0.4), rng(0,3), rng(0,0.4));
        cap.castShadow = true;
        this.scene.add(cap);
      }
    }

    // ---- 散落的碎石 ----
    const rubbleMat = new THREE.MeshStandardMaterial({ color: 0x2e2642, roughness: 1 });
    for (let i = 0; i < 40; i++) {
      const s = rng(0.3, 1.1);
      const geo = new THREE.DodecahedronGeometry(s, 0);
      const m = new THREE.Mesh(geo, rubbleMat);
      const ang = rng(0, Math.PI * 2), r = rng(3, ARENA_RADIUS - 1);
      m.position.set(Math.cos(ang) * r, s * 0.4, Math.sin(ang) * r);
      m.rotation.set(rng(0,3), rng(0,3), rng(0,3));
      m.castShadow = true; m.receiveShadow = true;
      this.scene.add(m);
    }

    // ---- 发光的魔法水晶（带点光源）----
    this.crystals = [];
    const crystalColors = [0x9a5aff, 0x5ac8ff, 0xff5aa8, 0x5affc8];
    for (let i = 0; i < 9; i++) {
      const col = crystalColors[i % crystalColors.length];
      const h = rng(2.5, 5);
      const geo = new THREE.ConeGeometry(rng(0.5, 1), h, 5);
      const mat = new THREE.MeshStandardMaterial({
        color: col, emissive: col, emissiveIntensity: 1.4,
        roughness: 0.2, metalness: 0.3, transparent: true, opacity: 0.9,
      });
      const c = new THREE.Mesh(geo, mat);
      const ang = rng(0, Math.PI * 2), r = rng(8, ARENA_RADIUS - 4);
      c.position.set(Math.cos(ang) * r, h / 2, Math.sin(ang) * r);
      c.rotation.z = rng(-0.2, 0.2);
      c.castShadow = true;
      this.scene.add(c);

      const light = new THREE.PointLight(col, 1.6, 20, 2);
      light.position.copy(c.position); light.position.y += h * 0.3;
      this.scene.add(light);
      this.crystals.push({ mesh: c, light, baseIntensity: 1.6, phase: rng(0, Math.PI * 2) });
    }

    // ---- 中央大水晶（地标）----
    const bigGeo = new THREE.OctahedronGeometry(2.2, 0);
    const bigMat = new THREE.MeshStandardMaterial({ color: 0xb98cff, emissive: 0x7a4aff, emissiveIntensity: 1.6, roughness: 0.1, metalness: 0.5, transparent: true, opacity: 0.85 });
    this.bigCrystal = new THREE.Mesh(bigGeo, bigMat);
    this.bigCrystal.position.set(0, 3.5, 0);
    this.bigCrystal.castShadow = true;
    this.scene.add(this.bigCrystal);
    const bigLight = new THREE.PointLight(0xb98cff, 2.2, 40, 2);
    bigLight.position.set(0, 5, 0);
    this.scene.add(bigLight);
    this.crystals.push({ mesh: this.bigCrystal, light: bigLight, baseIntensity: 2.2, phase: 0, isBig: true });

    // ---- 漂浮的尘埃/魔法微粒 ----
    const dustCount = 400;
    const dustGeo = new THREE.BufferGeometry();
    const dustPos = new Float32Array(dustCount * 3);
    for (let i = 0; i < dustCount; i++) {
      dustPos[i*3]   = rng(-ARENA_RADIUS, ARENA_RADIUS);
      dustPos[i*3+1] = rng(0.5, 18);
      dustPos[i*3+2] = rng(-ARENA_RADIUS, ARENA_RADIUS);
    }
    dustGeo.setAttribute('position', new THREE.BufferAttribute(dustPos, 3));
    const dustMat = new THREE.PointsMaterial({ color: 0xb9a2ff, size: 0.12, transparent: true, opacity: 0.5, depthWrite: false, blending: THREE.AdditiveBlending });
    this.dust = new THREE.Points(dustGeo, dustMat);
    this.scene.add(this.dust);
  }

  /* ---------------- 玩家初始化 ---------------- */
  initPlayer() {
    // 玩家由一个法师形体（身体 + 头 + 法杖光球）组成
    this.player = new THREE.Group();
    const bodyMat = new THREE.MeshStandardMaterial({ color: 0x3355aa, roughness: 0.6, emissive: 0x111a44, emissiveIntensity: 0.5 });
    const robe = new THREE.Mesh(new THREE.ConeGeometry(0.7, 1.7, 10), bodyMat);
    robe.position.y = 0.85; robe.castShadow = true;
    this.player.add(robe);
    const head = new THREE.Mesh(new THREE.SphereGeometry(0.32, 16, 16), new THREE.MeshStandardMaterial({ color: 0xe0c8a0, roughness: 0.7 }));
    head.position.y = 1.85; head.castShadow = true;
    this.player.add(head);
    // 帽子
    const hat = new THREE.Mesh(new THREE.ConeGeometry(0.42, 0.9, 10), bodyMat);
    hat.position.y = 2.35;
    this.player.add(hat);
    // 法杖顶端光球
    const orb = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 12), new THREE.MeshBasicMaterial({ color: 0x8fd4ff }));
    orb.position.set(0.55, 1.6, 0.2);
    this.player.add(orb);
    this.playerOrb = orb;
    const orbLight = new THREE.PointLight(0x8fd4ff, 1.2, 6, 2);
    orbLight.position.copy(orb.position);
    this.player.add(orbLight);

    this.scene.add(this.player);

    // 玩家逻辑状态
    this.player.position.set(0, 0, 12);
    this.playerVel = new THREE.Vector3();
  }

  /* ---------------- 缓存 HUD DOM ---------------- */
  cacheHud() {
    this.dom = {
      hud: document.getElementById('hud'),
      hpFill: document.getElementById('hp-fill'), hpLabel: document.getElementById('hp-label'),
      mpFill: document.getElementById('mp-fill'), mpLabel: document.getElementById('mp-label'),
      levelBadge: document.getElementById('level-badge'),
      xpFill: document.getElementById('xp-fill'), xpText: document.getElementById('xp-text'),
      waveNum: document.getElementById('wave-num'), enemyCount: document.getElementById('enemy-count'),
      waveTimer: document.getElementById('wave-timer'),
      statAtk: document.getElementById('stat-atk'), statSpd: document.getElementById('stat-spd'), statCrit: document.getElementById('stat-crit'),
      floating: document.getElementById('floating-layer'),
      toast: document.getElementById('toast'),
      banner: document.getElementById('wave-banner'), bannerBig: document.getElementById('banner-big'), bannerSmall: document.getElementById('banner-small'),
      inventory: document.getElementById('inventory'),
      passiveGrid: document.getElementById('passive-grid'),
      tooltip: document.getElementById('tooltip'),
      slots: [...document.querySelectorAll('#hotbar .slot')],
    };
  }

  /* ---------------- 事件绑定 ---------------- */
  bindEvents() {
    addEventListener('resize', () => {
      this.camera.aspect = innerWidth / innerHeight;
      this.camera.updateProjectionMatrix();
      this.renderer.setSize(innerWidth, innerHeight);
    });

    addEventListener('keydown', (e) => {
      const k = e.key.toLowerCase();
      this.keys[k] = true;
      if (this.state !== 'playing') return;
      if (k === 'i') this.toggleInventory();
      if (k === '1') this.castSkill(0);
      if (k === '2') this.castSkill(1);
      if (k === '3') this.castSkill(2);
    });
    addEventListener('keyup', (e) => { this.keys[e.key.toLowerCase()] = false; });

    // 指针锁定 + 鼠标视角
    const canvas = this.renderer.domElement;
    canvas.addEventListener('click', () => {
      if (this.state === 'playing' && !this.dom.inventory.classList.contains('open')) {
        canvas.requestPointerLock();
      }
    });
    document.addEventListener('pointerlockchange', () => {
      this.mouse.locked = (document.pointerLockElement === canvas);
    });
    addEventListener('mousemove', (e) => {
      if (!this.mouse.locked) return;
      this.cameraYaw   -= e.movementX * 0.0022;
      this.cameraPitch -= e.movementY * 0.0022;
      this.cameraPitch = Math.max(-0.2, Math.min(1.2, this.cameraPitch));
    });
    // 左键 = 火球
    addEventListener('mousedown', (e) => {
      if (e.button === 0 && this.state === 'playing' && this.mouse.locked) this.castSkill(0);
    });

    // 亮度滑块
    const brightness = document.getElementById('brightness');
    const brightnessVal = document.getElementById('brightness-val');
    brightness.addEventListener('input', () => {
      const v = parseInt(brightness.value);
      brightnessVal.textContent = v;
      this.brightnessMult = v / 100;
      this.applyBrightness();
    });

    // 热键栏点击释放
    this.dom = this.dom || {};
    document.querySelectorAll('#hotbar .slot').forEach(slot => {
      slot.addEventListener('click', () => this.castSkill(parseInt(slot.dataset.skill)));
    });

    // 菜单按钮
    document.getElementById('btn-new').addEventListener('click', () => this.startRun(true));
    document.getElementById('btn-continue').addEventListener('click', () => this.startRun(false));
    document.getElementById('btn-restart').addEventListener('click', () => this.startRun(true));
    document.getElementById('btn-menu').addEventListener('click', () => {
      document.getElementById('gameover').classList.add('hidden');
      this.showMenu();
    });
  }

  applyBrightness() {
    const m = this.brightnessMult;
    this.ambient.intensity = 0.6 * m;
    this.hemi.intensity = 0.5 * m;
    this.moon.intensity = 0.7 * m;
    this.renderer.toneMappingExposure = 0.6 + 0.6 * m;
  }

  /* ============================================================
     3. 存档系统（localStorage）
  ============================================================ */
  loadSave() {
    try {
      const raw = localStorage.getItem(SAVE_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch { return null; }
  }
  writeSave() {
    const s = this.stats;
    const data = {
      level: s.level, xp: s.xp, xpNext: s.xpNext,
      maxHpBonus: s.maxHpBonus, maxMpBonus: s.maxMpBonus,
      relics: this.relicCounts,
      bestWave: Math.max(this.bestWave || 0, this.wave),
    };
    try { localStorage.setItem(SAVE_KEY, JSON.stringify(data)); } catch {}
  }
  clearSave() { try { localStorage.removeItem(SAVE_KEY); } catch {} }

  /* ---------------- 主菜单 ---------------- */
  showMenu() {
    this.state = 'menu';
    this.dom.hud.classList.add('hidden');
    document.getElementById('gameover').classList.add('hidden');
    const menu = document.getElementById('main-menu');
    menu.classList.remove('hidden');
    if (document.pointerLockElement) document.exitPointerLock();

    const save = this.loadSave();
    const preview = document.getElementById('save-preview');
    const btnContinue = document.getElementById('btn-continue');
    if (save) {
      btnContinue.disabled = false;
      preview.classList.remove('none');
      const relicTotal = Object.values(save.relics || {}).reduce((a, b) => a + b, 0);
      preview.innerHTML = `存档进度 · 等级 <b>${save.level}</b> · 最高波次 <b>${save.bestWave || 0}</b><br>圣物 <b>${relicTotal}</b> 件 · 生命加成 <b>+${save.maxHpBonus || 0}</b>`;
    } else {
      btnContinue.disabled = true;
      preview.classList.add('none');
      preview.textContent = '暂无存档 — 开始你的第一段征程吧';
    }
  }

  /* ============================================================
     4. 开始一局游戏
  ============================================================ */
  startRun(isNew) {
    // 音频需在用户手势内初始化
    this.audio.init();
    this.audio.resume();
    this.audio.startDrone();

    const save = (!isNew && this.loadSave()) || null;

    // ---- 基础属性 ----
    this.stats = {
      level: save ? save.level : 1,
      xp: save ? save.xp : 0,
      xpNext: save ? save.xpNext : 100,
      baseMaxHp: 100, baseMaxMp: 100, baseAtk: 10, baseSpeed: 6.0, baseCrit: 0.10,
      // 圣物加成（先清零，稍后按圣物重算）
      maxHpBonus: 0, maxMpBonus: 0,
      atkMult: 1, speedMult: 1, critBonus: 0,
      lifesteal: 0, manaDiscount: 0, mpRegenBonus: 0,
    };
    // 等级带来的属性成长
    const lvlBonus = (this.stats.level - 1);
    this.stats.baseMaxHp += lvlBonus * 12;
    this.stats.baseMaxMp += lvlBonus * 8;
    this.stats.baseAtk += lvlBonus * 2;

    // ---- 圣物 ----
    this.relicCounts = {};
    RELIC_KEYS.forEach(k => this.relicCounts[k] = 0);
    if (save && save.relics) {
      for (const k of RELIC_KEYS) this.relicCounts[k] = save.relics[k] || 0;
    }
    // 保存中的额外 bonus（旧版兼容，忽略；用圣物重算）
    this.recomputeStats();

    // ---- 当前生命/法力拉满 ----
    this.hp = this.maxHp;
    this.mp = this.maxMp;

    // ---- 波次/世界 ----
    this.wave = 0;
    this.bestWave = save ? (save.bestWave || 0) : 0;
    this.waveState = 'intro';    // intro | active | cleared
    this.waveTimer = 1.5;
    this.enemiesToSpawn = [];
    this.spawnTimer = 0;
    this.runKills = 0;
    this.runStartTime = performance.now();

    // ---- 清理场上对象 ----
    this.clearEntities();

    // ---- 玩家复位 ----
    this.player.position.set(0, 0, 12);
    this.playerVel.set(0, 0, 0);
    this.cameraYaw = Math.PI;   // 面向场景中心
    this.cameraPitch = 0.35;
    this.skillCooldowns = [0, 0, 0];

    // ---- UI ----
    document.getElementById('main-menu').classList.add('hidden');
    document.getElementById('gameover').classList.add('hidden');
    this.dom.hud.classList.remove('hidden');
    this.dom.inventory.classList.remove('open');
    this.renderPassiveGrid();
    this.applyBrightness();
    this.updateHud();

    this.state = 'playing';
    this.writeSave();  // 立即存一次
  }

  clearEntities() {
    [...this.enemies, ...this.projectiles, ...this.enemyProjectiles, ...this.orbs].forEach(e => {
      if (e.mesh) this.scene.remove(e.mesh);
    });
    this.aoeEffects.forEach(a => this.scene.remove(a.mesh));
    this.particleBursts.forEach(p => this.scene.remove(p.points));
    this.enemies = []; this.projectiles = []; this.enemyProjectiles = [];
    this.orbs = []; this.aoeEffects = []; this.particleBursts = [];
  }

  /* ---------------- 根据圣物 + 等级重算最终属性 ---------------- */
  recomputeStats() {
    const s = this.stats;
    // 每次重算前把圣物 bonus 归零，再按当前圣物数量累加
    s.maxHpBonus = 0; s.maxMpBonus = 0;
    s.atkMult = 1; s.speedMult = 1; s.critBonus = 0;
    s.lifesteal = 0; s.manaDiscount = 0; s.mpRegenBonus = 0;
    for (const k of RELIC_KEYS) {
      const count = this.relicCounts[k] || 0;
      for (let i = 0; i < count; i++) RELICS[k].apply(s);
    }
    this.maxHp = s.baseMaxHp + s.maxHpBonus;
    this.maxMp = s.baseMaxMp + s.maxMpBonus;
    this.atk = s.baseAtk * s.atkMult;
    this.speed = s.baseSpeed * s.speedMult;
    this.crit = Math.min(0.9, s.baseCrit + s.critBonus);
  }

  /* ============================================================
     5. 波次与刷怪
  ============================================================ */
  startWave(n) {
    this.wave = n;
    this.waveState = 'active';
    // 根据波次组合敌人；随波次数量与强度递增
    const list = [];
    const gruntN = 3 + Math.floor(n * 1.5);
    const cultistN = n >= 2 ? Math.floor(n * 0.8) : 0;
    const bruteN = n >= 3 ? Math.floor((n - 2) / 2) + 1 : 0;
    for (let i = 0; i < gruntN; i++) list.push('grunt');
    for (let i = 0; i < cultistN; i++) list.push('cultist');
    for (let i = 0; i < bruteN; i++) list.push('brute');
    // 打乱
    for (let i = list.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [list[i], list[j]] = [list[j], list[i]]; }
    this.enemiesToSpawn = list;
    this.spawnTimer = 0;
    this.waveDifficulty = 1 + (n - 1) * 0.15;   // 敌人 hp/dmg 缩放

    // UI 横幅 + 音效
    this.dom.bannerBig.textContent = `第 ${n} 波`;
    this.dom.bannerSmall.textContent = `${list.length} 个敌人来袭`;
    this.dom.banner.classList.remove('show'); void this.dom.banner.offsetWidth;
    this.dom.banner.classList.add('show');
    this.audio.waveStart();
    this.updateHud();
  }

  spawnEnemy(type) {
    const proto = ENEMY_TYPES[type];
    const g = new THREE.Group();

    // 依类型构建外观
    let bodyColor = proto.color;
    if (type === 'grunt') {
      const torso = new THREE.Mesh(new THREE.CapsuleGeometry(0.4, 0.8, 4, 8), new THREE.MeshStandardMaterial({ color: bodyColor, roughness: 0.9 }));
      torso.position.y = 0.9; torso.castShadow = true; g.add(torso);
      const head = new THREE.Mesh(new THREE.SphereGeometry(0.3, 12, 12), new THREE.MeshStandardMaterial({ color: 0x8fae5a, roughness: 0.9 }));
      head.position.y = 1.7; head.castShadow = true; g.add(head);
    } else if (type === 'cultist') {
      const robe = new THREE.Mesh(new THREE.ConeGeometry(0.55, 1.6, 8), new THREE.MeshStandardMaterial({ color: bodyColor, roughness: 0.7, emissive: 0x3a1a5a, emissiveIntensity: 0.5 }));
      robe.position.y = 0.8; robe.castShadow = true; g.add(robe);
      const hood = new THREE.Mesh(new THREE.ConeGeometry(0.3, 0.6, 8), new THREE.MeshStandardMaterial({ color: 0x2a1040 }));
      hood.position.y = 1.7; g.add(hood);
    } else { // brute
      const body = new THREE.Mesh(new THREE.BoxGeometry(1.4, 1.8, 1.2), new THREE.MeshStandardMaterial({ color: bodyColor, roughness: 0.85, emissive: 0x3a1000, emissiveIntensity: 0.3 }));
      body.position.y = 1.5; body.castShadow = true; g.add(body);
      const head = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.7, 0.8), new THREE.MeshStandardMaterial({ color: 0xd0603a, roughness: 0.85 }));
      head.position.y = 2.7; head.castShadow = true; g.add(head);
      // 双臂
      [-1, 1].forEach(sx => {
        const arm = new THREE.Mesh(new THREE.BoxGeometry(0.4, 1.3, 0.4), body.material);
        arm.position.set(sx * 1.0, 1.5, 0); arm.castShadow = true; g.add(arm);
      });
    }

    // 出生位置：竞技场边缘随机
    const ang = Math.random() * Math.PI * 2;
    const r = ARENA_RADIUS - 3;
    g.position.set(Math.cos(ang) * r, 0, Math.sin(ang) * r);
    g.scale.setScalar(proto.scale);
    this.scene.add(g);

    const diff = this.waveDifficulty;
    this.enemies.push({
      mesh: g, type,
      hp: proto.hp * diff, maxHp: proto.hp * diff,
      speed: proto.speed, dmg: proto.dmg * diff,
      radius: proto.radius * proto.scale, xp: proto.xp,
      ranged: !!proto.ranged, range: proto.range || 0,
      projSpeed: proto.projSpeed || 0, fireTimer: Math.random() * 2,
      fireRate: proto.fireRate || 0,
      telegraph: proto.telegraph || 0, telegraphTimer: 0, telegraphing: false,
      attackCd: 0,
      hitFlash: 0, frozen: 0,
      materials: this.collectMaterials(g),
    });
  }

  // 收集一个 group 内所有 mesh 的材质（用于命中闪红）
  collectMaterials(group) {
    const mats = [];
    group.traverse(o => { if (o.isMesh) mats.push({ mat: o.material, base: o.material.color.clone(), baseEmissive: o.material.emissive ? o.material.emissive.clone() : null }); });
    return mats;
  }

  /* ============================================================
     6. 技能释放
  ============================================================ */
  getAimDirection() {
    // 依据相机朝向得到水平前向
    const dir = new THREE.Vector3();
    this.camera.getWorldDirection(dir);
    dir.y = 0;
    if (dir.lengthSq() < 0.0001) dir.set(0, 0, -1);
    dir.normalize();
    return dir;
  }

  castSkill(idx) {
    if (this.state !== 'playing') return;
    if (this.skillCooldowns[idx] > 0) return;
    const skill = SKILLS[idx];
    const cost = skill.manaCost * (1 - this.stats.manaDiscount);
    if (this.mp < cost) { this.toast('法力不足！'); return; }

    this.mp -= cost;
    this.skillCooldowns[idx] = skill.cooldown;
    this.audio.cast(skill.id);

    const origin = this.player.position.clone(); origin.y = 1.4;
    const dir = this.getAimDirection();

    if (skill.id === 'fireball') {
      this.spawnFireball(origin, dir);
    } else if (skill.id === 'frost') {
      this.castFrostNova();
    } else if (skill.id === 'dash') {
      this.castDash(dir);
    }
    // 法杖光球闪烁
    this.playerOrb.material.color.setHex(skill.color);
    this.updateHud();
  }

  spawnFireball(origin, dir) {
    const mesh = new THREE.Mesh(
      new THREE.SphereGeometry(0.3, 12, 12),
      new THREE.MeshBasicMaterial({ color: 0xff8a3a })
    );
    mesh.position.copy(origin);
    const light = new THREE.PointLight(0xff6a2b, 1.5, 8, 2);
    mesh.add(light);
    this.scene.add(mesh);
    const isCrit = Math.random() < this.crit;
    this.projectiles.push({
      mesh, dir: dir.clone(), speed: 26, life: 2.2,
      dmg: this.atk * (isCrit ? 2 : 1) * 1.0, crit: isCrit, radius: 0.6,
      kind: 'fireball',
    });
  }

  castFrostNova() {
    // 以玩家为中心的环形 AoE，冻结并伤害范围内敌人
    const radius = 9;
    const center = this.player.position.clone();
    const ring = new THREE.Mesh(
      new THREE.RingGeometry(0.5, 1, 48),
      new THREE.MeshBasicMaterial({ color: 0x8fe0ff, transparent: true, opacity: 0.7, side: THREE.DoubleSide })
    );
    ring.rotation.x = -Math.PI / 2; ring.position.copy(center); ring.position.y = 0.1;
    this.scene.add(ring);
    this.aoeEffects.push({ mesh: ring, life: 0.6, maxLife: 0.6, maxR: radius, kind: 'frost' });

    const dmg = this.atk * 0.8;
    for (const e of this.enemies) {
      if (e.mesh.position.distanceTo(center) <= radius) {
        const isCrit = Math.random() < this.crit;
        this.damageEnemy(e, dmg * (isCrit ? 2 : 1), isCrit);
        e.frozen = 2.5;   // 冻结 2.5 秒
      }
    }
  }

  castDash(dir) {
    // 沿瞄准方向瞬间位移，并对沿途敌人造成雷电伤害
    const dist = 8;
    const start = this.player.position.clone();
    const end = start.clone().addScaledVector(dir, dist);
    // 限制在竞技场内
    if (end.length() > ARENA_RADIUS - 2) end.setLength(ARENA_RADIUS - 2);
    // 雷电轨迹特效
    this.spawnDashTrail(start, end);

    const dmg = this.atk * 1.2;
    const path = end.clone().sub(start);
    const pathLen = path.length();
    const pathDir = path.clone().normalize();
    for (const e of this.enemies) {
      // 点到线段距离
      const toE = e.mesh.position.clone().sub(start);
      const proj = THREE.MathUtils.clamp(toE.dot(pathDir), 0, pathLen);
      const closest = start.clone().addScaledVector(pathDir, proj);
      if (e.mesh.position.distanceTo(closest) < 2.5 + e.radius) {
        const isCrit = Math.random() < this.crit;
        this.damageEnemy(e, dmg * (isCrit ? 2 : 1), isCrit);
      }
    }
    this.player.position.copy(end);
    this.dashInvuln = 0.3;   // 短暂无敌
  }

  spawnDashTrail(a, b) {
    const pts = [a.clone().setY(1), b.clone().setY(1)];
    const geo = new THREE.BufferGeometry().setFromPoints(pts);
    const line = new THREE.Line(geo, new THREE.LineBasicMaterial({ color: 0xffe14d, transparent: true, opacity: 1 }));
    this.scene.add(line);
    this.aoeEffects.push({ mesh: line, life: 0.35, maxLife: 0.35, kind: 'dash' });
    this.spawnParticles(b.clone().setY(1), 0xffe14d, 16);
  }

  /* ============================================================
     7. 伤害 / 粒子 / 掉落
  ============================================================ */
  damageEnemy(e, dmg, isCrit) {
    dmg = Math.round(dmg);
    e.hp -= dmg;
    e.hitFlash = 0.15;
    this.floatText(e.mesh.position, dmg, isCrit ? 'crit' : 'enemy', isCrit);

    // 吸血
    if (this.stats.lifesteal > 0) {
      const heal = dmg * this.stats.lifesteal;
      this.hp = Math.min(this.maxHp, this.hp + heal);
    }
    if (e.hp <= 0) this.killEnemy(e);
    this.updateHud();
  }

  killEnemy(e) {
    e.dead = true;
    this.runKills++;
    this.audio.enemyDie();
    // 溶解粒子
    this.spawnParticles(e.mesh.position.clone().setY(1), ENEMY_TYPES[e.type].color, 24);
    // 掉落经验球
    this.spawnOrb(e.mesh.position.clone(), e.xp);
    this.scene.remove(e.mesh);
  }

  spawnParticles(pos, color, count) {
    const geo = new THREE.BufferGeometry();
    const positions = new Float32Array(count * 3);
    const velocities = [];
    for (let i = 0; i < count; i++) {
      positions[i*3] = pos.x; positions[i*3+1] = pos.y; positions[i*3+2] = pos.z;
      velocities.push(new THREE.Vector3(
        (Math.random()-0.5)*8, Math.random()*7, (Math.random()-0.5)*8
      ));
    }
    geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    const mat = new THREE.PointsMaterial({ color, size: 0.3, transparent: true, opacity: 1, blending: THREE.AdditiveBlending, depthWrite: false });
    const points = new THREE.Points(geo, mat);
    this.scene.add(points);
    this.particleBursts.push({ points, velocities, life: 0.8, maxLife: 0.8 });
  }

  spawnOrb(pos, xp) {
    const mesh = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.28, 0),
      new THREE.MeshBasicMaterial({ color: 0xffd24d })
    );
    mesh.position.copy(pos); mesh.position.y = 0.6;
    const light = new THREE.PointLight(0xffd24d, 0.8, 4, 2);
    mesh.add(light);
    this.scene.add(mesh);
    // 有几率掉落圣物（发光颜色不同）
    let relic = null;
    if (Math.random() < 0.16) {
      relic = RELIC_KEYS[Math.floor(Math.random() * RELIC_KEYS.length)];
      mesh.material.color.setHex(0xb98cff);
      light.color.setHex(0xb98cff);
    }
    this.orbs.push({ mesh, xp, relic, phase: Math.random() * Math.PI * 2, life: 25 });
  }

  /* ---------------- 经验 / 升级 ---------------- */
  gainXp(amount) {
    this.stats.xp += amount;
    while (this.stats.xp >= this.stats.xpNext) {
      this.stats.xp -= this.stats.xpNext;
      this.levelUp();
    }
    this.updateHud();
  }

  levelUp() {
    this.stats.level++;
    this.stats.xpNext = Math.floor(this.stats.xpNext * 1.35 + 20);
    // 成长
    this.stats.baseMaxHp += 12;
    this.stats.baseMaxMp += 8;
    this.stats.baseAtk += 2;
    this.recomputeStats();
    // 升级回满
    this.hp = this.maxHp;
    this.mp = this.maxMp;
    this.audio.levelup();
    this.toast(`✦ 升级！ 等级 ${this.stats.level} ✦`);
    this.spawnParticles(this.player.position.clone().setY(1.5), 0xffd24d, 40);
    this.writeSave();
  }

  /* ============================================================
     8. 玩家受伤 / 死亡
  ============================================================ */
  damagePlayer(dmg) {
    if (this.dashInvuln > 0) return;
    dmg = Math.round(dmg);
    this.hp -= dmg;
    this.audio.hurt();
    this.floatText(this.player.position.clone().setY(2.3), dmg, 'player');
    // 屏幕红闪
    this.flashDamage();
    if (this.hp <= 0) { this.hp = 0; this.die(); }
    this.updateHud();
  }

  flashDamage() {
    let f = document.getElementById('dmg-flash');
    if (!f) {
      f = document.createElement('div');
      f.id = 'dmg-flash';
      f.style.cssText = 'position:fixed;inset:0;z-index:12;pointer-events:none;background:radial-gradient(circle,transparent 40%,rgba(255,30,50,0.5));opacity:0;transition:opacity 0.1s;';
      document.body.appendChild(f);
    }
    f.style.opacity = '1';
    setTimeout(() => { f.style.opacity = '0'; }, 120);
  }

  die() {
    this.state = 'dead';
    if (document.pointerLockElement) document.exitPointerLock();
    // 记录最高波次并清档
    const finalBest = Math.max(this.bestWave, this.wave);
    const runTime = Math.floor((performance.now() - this.runStartTime) / 1000);
    const relicTotal = Object.values(this.relicCounts).reduce((a, b) => a + b, 0);

    // 结束画面统计
    const stats = document.getElementById('gameover-stats');
    stats.innerHTML = `
      <div class="row"><span class="k">达到波次</span><span class="v">${this.wave}</span></div>
      <div class="row"><span class="k">角色等级</span><span class="v">${this.stats.level}</span></div>
      <div class="row"><span class="k">击杀数</span><span class="v">${this.runKills}</span></div>
      <div class="row"><span class="k">收集圣物</span><span class="v">${relicTotal}</span></div>
      <div class="row"><span class="k">历史最高波次</span><span class="v">${finalBest}</span></div>
      <div class="row"><span class="k">生存时间</span><span class="v">${Math.floor(runTime/60)}分${runTime%60}秒</span></div>
    `;
    // 死亡即清空当前存档（roguelike 永久死亡）
    this.clearSave();
    setTimeout(() => document.getElementById('gameover').classList.remove('hidden'), 600);
  }

  /* ============================================================
     9. 主循环
  ============================================================ */
  loop() {
    const dt = Math.min(this.clock.getDelta(), 0.05);
    this.animateAmbient(dt);
    if (this.state === 'playing') {
      this.updatePlayer(dt);
      this.updateWaves(dt);
      this.updateEnemies(dt);
      this.updateProjectiles(dt);
      this.updateEnemyProjectiles(dt);
      this.updateOrbs(dt);
      this.updateCooldowns(dt);
      this.regen(dt);
    }
    this.updateParticles(dt);
    this.updateAoe(dt);
    this.updateCamera(dt);
    this.renderer.render(this.scene, this.camera);
  }

  // 场景恒定动画（水晶脉动、尘埃漂浮），无论状态如何
  animateAmbient(dt) {
    const t = performance.now() * 0.001;
    for (const c of this.crystals) {
      const pulse = 1 + Math.sin(t * 1.2 + c.phase) * 0.25;
      c.light.intensity = c.baseIntensity * pulse * this.brightnessMult;
      c.mesh.material.emissiveIntensity = (c.isBig ? 1.6 : 1.4) * pulse;
      if (c.isBig) c.mesh.rotation.y += dt * 0.3;
    }
    if (this.bigCrystal) this.bigCrystal.rotation.y += dt * 0.2;
    // 尘埃缓慢上升并循环
    if (this.dust) {
      const pos = this.dust.geometry.attributes.position;
      for (let i = 0; i < pos.count; i++) {
        let y = pos.getY(i) + dt * 0.3;
        if (y > 18) y = 0.5;
        pos.setY(i, y);
      }
      pos.needsUpdate = true;
      this.dust.rotation.y += dt * 0.01;
    }
    if (this.playerOrb) {
      // 光球颜色缓慢回到默认蓝
      this.playerOrb.material.color.lerp(new THREE.Color(0x8fd4ff), dt * 3);
    }
  }

  updatePlayer(dt) {
    if (this.dashInvuln > 0) this.dashInvuln -= dt;
    // 若背包打开则暂停移动输入
    const invOpen = this.dom.inventory.classList.contains('open');
    const move = new THREE.Vector3();
    if (!invOpen) {
      // 相对相机的移动方向
      const forward = new THREE.Vector3(-Math.sin(this.cameraYaw), 0, -Math.cos(this.cameraYaw));
      const right = new THREE.Vector3(Math.cos(this.cameraYaw), 0, -Math.sin(this.cameraYaw));
      if (this.keys['w']) move.add(forward);
      if (this.keys['s']) move.sub(forward);
      if (this.keys['d']) move.add(right);
      if (this.keys['a']) move.sub(right);
    }
    if (move.lengthSq() > 0) {
      move.normalize();
      this.player.position.addScaledVector(move, this.speed * dt);
      // 朝向移动方向
      const targetAngle = Math.atan2(move.x, move.z);
      this.player.rotation.y = this.lerpAngle(this.player.rotation.y, targetAngle, dt * 12);
    }
    // 限制在竞技场内
    const d = Math.hypot(this.player.position.x, this.player.position.z);
    if (d > ARENA_RADIUS - 2) {
      const s = (ARENA_RADIUS - 2) / d;
      this.player.position.x *= s; this.player.position.z *= s;
    }
  }

  lerpAngle(a, b, t) {
    let diff = b - a;
    while (diff > Math.PI) diff -= Math.PI * 2;
    while (diff < -Math.PI) diff += Math.PI * 2;
    return a + diff * Math.min(1, t);
  }

  updateWaves(dt) {
    if (this.waveState === 'intro') {
      this.waveTimer -= dt;
      this.dom.waveTimer.textContent = `下一波: ${Math.ceil(this.waveTimer)}s`;
      if (this.waveTimer <= 0) this.startWave(this.wave + 1);
      return;
    }
    if (this.waveState === 'active') {
      // 逐个刷出待生成敌人
      if (this.enemiesToSpawn.length > 0) {
        this.spawnTimer -= dt;
        if (this.spawnTimer <= 0) {
          this.spawnEnemy(this.enemiesToSpawn.shift());
          this.spawnTimer = 0.6;
        }
      }
      this.dom.waveTimer.textContent = '';
      // 全部清空 → 进入下一波间歇
      if (this.enemiesToSpawn.length === 0 && this.enemies.length === 0) {
        this.waveState = 'intro';
        this.waveTimer = 5;
        this.bestWave = Math.max(this.bestWave, this.wave);
        this.toast(`第 ${this.wave} 波清剿完毕！`);
        this.writeSave();
      }
    }
  }

  updateEnemies(dt) {
    const alive = [];
    for (const e of this.enemies) {
      if (e.dead) continue;

      // 命中闪红处理
      if (e.hitFlash > 0) {
        e.hitFlash -= dt;
        const flashing = e.hitFlash > 0;
        for (const m of e.materials) {
          m.mat.color.copy(flashing ? new THREE.Color(0xff3030) : m.base);
        }
      }

      // 冻结状态
      let speedMul = 1;
      if (e.frozen > 0) {
        e.frozen -= dt; speedMul = 0.25;
        for (const m of e.materials) m.mat.color.lerp(new THREE.Color(0x8fd4ff), 0.3);
      }

      const toPlayer = this.player.position.clone().sub(e.mesh.position);
      toPlayer.y = 0;
      const dist = toPlayer.length();
      toPlayer.normalize();

      if (e.ranged) {
        // 远程：保持距离并射击
        if (dist > e.range) e.mesh.position.addScaledVector(toPlayer, e.speed * speedMul * dt);
        else if (dist < e.range - 4) e.mesh.position.addScaledVector(toPlayer, -e.speed * speedMul * dt);
        e.fireTimer -= dt;
        if (e.fireTimer <= 0 && dist <= e.range && e.frozen <= 0) {
          e.fireTimer = e.fireRate;
          this.spawnEnemyProjectile(e);
        }
      } else {
        // 近战：追击玩家
        const stopDist = e.radius + 1.2;
        if (dist > stopDist) {
          e.mesh.position.addScaledVector(toPlayer, e.speed * speedMul * dt);
        } else {
          // 巨兽有前摇（telegraph）
          if (e.telegraph > 0) {
            if (!e.telegraphing && e.attackCd <= 0) {
              e.telegraphing = true; e.telegraphTimer = e.telegraph;
            }
            if (e.telegraphing) {
              e.telegraphTimer -= dt;
              // 前摇时放大+变红
              const s = ENEMY_TYPES[e.type].scale * (1 + (e.telegraph - e.telegraphTimer) * 0.15);
              e.mesh.scale.setScalar(s);
              if (e.telegraphTimer <= 0) {
                e.telegraphing = false;
                e.mesh.scale.setScalar(ENEMY_TYPES[e.type].scale);
                if (dist <= stopDist + 0.5) this.damagePlayer(e.dmg);
                e.attackCd = 1.5;
              }
            }
          } else {
            if (e.attackCd <= 0) { this.damagePlayer(e.dmg); e.attackCd = 1.0; }
          }
        }
      }
      if (e.attackCd > 0) e.attackCd -= dt;

      // 朝向玩家
      e.mesh.rotation.y = Math.atan2(toPlayer.x, toPlayer.z);
      // 简单的上下浮动动画
      e.mesh.position.y = Math.abs(Math.sin(performance.now() * 0.005 + e.mesh.id)) * 0.1;

      alive.push(e);
    }
    this.enemies = alive;
    this.dom.enemyCount.textContent = `敌人: ${this.enemies.length + this.enemiesToSpawn.length}`;
  }

  spawnEnemyProjectile(e) {
    const origin = e.mesh.position.clone(); origin.y = 1.3;
    const dir = this.player.position.clone().setY(1.3).sub(origin).normalize();
    const mesh = new THREE.Mesh(
      new THREE.SphereGeometry(0.25, 10, 10),
      new THREE.MeshBasicMaterial({ color: 0xb44aff })
    );
    mesh.position.copy(origin);
    const light = new THREE.PointLight(0x8a2aff, 1, 5, 2); mesh.add(light);
    this.scene.add(mesh);
    this.enemyProjectiles.push({ mesh, dir, speed: e.projSpeed, dmg: e.dmg, life: 4, radius: 0.4 });
  }

  updateProjectiles(dt) {
    const alive = [];
    for (const p of this.projectiles) {
      p.life -= dt;
      p.mesh.position.addScaledVector(p.dir, p.speed * dt);
      // 火焰拖尾
      if (Math.random() < 0.5) this.spawnTrailSpark(p.mesh.position, 0xff8a3a);
      let hit = false;
      for (const e of this.enemies) {
        if (e.mesh.position.distanceTo(p.mesh.position) < e.radius + p.radius) {
          const isCrit = p.crit;
          this.damageEnemy(e, p.dmg, isCrit);
          this.audio.impact();
          this.spawnParticles(p.mesh.position.clone(), 0xff6a2b, 14);
          hit = true; break;
        }
      }
      if (hit || p.life <= 0 || p.mesh.position.length() > ARENA_RADIUS + 5) {
        this.scene.remove(p.mesh);
      } else alive.push(p);
    }
    this.projectiles = alive;
  }

  spawnTrailSpark(pos, color) {
    // 轻量拖尾：复用粒子系统的单点
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(new Float32Array([pos.x, pos.y, pos.z]), 3));
    const mat = new THREE.PointsMaterial({ color, size: 0.4, transparent: true, opacity: 0.8, blending: THREE.AdditiveBlending, depthWrite: false });
    const pts = new THREE.Points(geo, mat);
    this.scene.add(pts);
    this.particleBursts.push({ points: pts, velocities: [new THREE.Vector3(0, 0.5, 0)], life: 0.3, maxLife: 0.3 });
  }

  updateEnemyProjectiles(dt) {
    const alive = [];
    for (const p of this.enemyProjectiles) {
      p.life -= dt;
      p.mesh.position.addScaledVector(p.dir, p.speed * dt);
      let hit = false;
      if (p.mesh.position.distanceTo(this.player.position.clone().setY(1.3)) < 1.0 + p.radius) {
        this.damagePlayer(p.dmg);
        this.spawnParticles(p.mesh.position.clone(), 0xb44aff, 12);
        hit = true;
      }
      if (hit || p.life <= 0 || p.mesh.position.length() > ARENA_RADIUS + 5) {
        this.scene.remove(p.mesh);
      } else alive.push(p);
    }
    this.enemyProjectiles = alive;
  }

  updateOrbs(dt) {
    const alive = [];
    for (const o of this.orbs) {
      o.life -= dt;
      o.phase += dt * 3;
      o.mesh.position.y = 0.6 + Math.sin(o.phase) * 0.15;
      o.mesh.rotation.y += dt * 2;
      const dist = o.mesh.position.distanceTo(this.player.position);
      // 磁吸
      if (dist < 5) {
        const pull = this.player.position.clone().sub(o.mesh.position).normalize();
        o.mesh.position.addScaledVector(pull, (6 - dist) * dt * 2);
      }
      if (dist < 1.2) {
        // 拾取
        this.gainXp(o.xp);
        this.audio.pickup();
        if (o.relic) this.pickupRelic(o.relic);
        this.scene.remove(o.mesh);
        continue;
      }
      if (o.life <= 0) { this.scene.remove(o.mesh); continue; }
      alive.push(o);
    }
    this.orbs = alive;
  }

  pickupRelic(key) {
    this.relicCounts[key] = (this.relicCounts[key] || 0) + 1;
    this.recomputeStats();
    // 拾取时补满因加成而增长的生命/法力上限差额
    this.hp = Math.min(this.maxHp, this.hp + 30);
    const r = RELICS[key];
    this.toast(`获得圣物：${r.icon} ${r.name}`);
    this.renderPassiveGrid();
    this.writeSave();
    this.updateHud();
  }

  updateCooldowns(dt) {
    for (let i = 0; i < this.skillCooldowns.length; i++) {
      if (this.skillCooldowns[i] > 0) {
        this.skillCooldowns[i] -= dt;
        if (this.skillCooldowns[i] < 0) this.skillCooldowns[i] = 0;
      }
      // 更新冷却遮罩
      const overlay = this.dom.slots[i].querySelector('.cd-overlay');
      const ratio = this.skillCooldowns[i] / SKILLS[i].cooldown;
      overlay.style.transform = `scaleY(${Math.max(0, ratio)})`;
      // 法力不足视觉
      const cost = SKILLS[i].manaCost * (1 - this.stats.manaDiscount);
      this.dom.slots[i].classList.toggle('no-mana', this.mp < cost);
    }
  }

  regen(dt) {
    // 法力自然回复
    this.mp = Math.min(this.maxMp, this.mp + (6 + this.stats.mpRegenBonus) * dt);
    // 生命极缓慢回复
    this.hp = Math.min(this.maxHp, this.hp + 0.5 * dt);
    this.updateHudBars();
  }

  updateParticles(dt) {
    const alive = [];
    for (const b of this.particleBursts) {
      b.life -= dt;
      const pos = b.points.geometry.attributes.position;
      for (let i = 0; i < b.velocities.length; i++) {
        const v = b.velocities[i];
        v.y -= 12 * dt;   // 重力
        pos.setXYZ(i, pos.getX(i) + v.x * dt, pos.getY(i) + v.y * dt, pos.getZ(i) + v.z * dt);
      }
      pos.needsUpdate = true;
      b.points.material.opacity = Math.max(0, b.life / b.maxLife);
      if (b.life <= 0) { this.scene.remove(b.points); b.points.geometry.dispose(); b.points.material.dispose(); }
      else alive.push(b);
    }
    this.particleBursts = alive;
  }

  updateAoe(dt) {
    const alive = [];
    for (const a of this.aoeEffects) {
      a.life -= dt;
      const t = 1 - a.life / a.maxLife;
      if (a.kind === 'frost') {
        const r = a.maxR * t;
        a.mesh.scale.setScalar(r);
        a.mesh.material.opacity = 0.7 * (1 - t);
      } else if (a.kind === 'dash') {
        a.mesh.material.opacity = a.life / a.maxLife;
      }
      if (a.life <= 0) { this.scene.remove(a.mesh); }
      else alive.push(a);
    }
    this.aoeEffects = alive;
  }

  updateCamera(dt) {
    // 第三人称跟随相机：基于 yaw/pitch 环绕玩家
    const target = this.player.position.clone(); target.y += 1.6;
    const offset = new THREE.Vector3(
      Math.sin(this.cameraYaw) * Math.cos(this.cameraPitch),
      Math.sin(this.cameraPitch),
      Math.cos(this.cameraYaw) * Math.cos(this.cameraPitch)
    ).multiplyScalar(this.cameraDist);
    const desired = target.clone().add(offset);
    this.camera.position.lerp(desired, Math.min(1, dt * 10));
    this.camera.lookAt(target);
  }

  /* ============================================================
     10. HUD 更新
  ============================================================ */
  updateHud() {
    this.updateHudBars();
    this.dom.levelBadge.textContent = this.stats.level;
    this.dom.waveNum.textContent = this.wave;
    this.dom.statAtk.textContent = Math.round(this.atk);
    this.dom.statSpd.textContent = this.speed.toFixed(1);
    this.dom.statCrit.textContent = Math.round(this.crit * 100) + '%';
    // 背包属性
    if (this.dom.inventory.classList.contains('open')) this.updateInventoryStats();
  }

  updateHudBars() {
    const hpPct = Math.max(0, this.hp / this.maxHp) * 100;
    const mpPct = Math.max(0, this.mp / this.maxMp) * 100;
    this.dom.hpFill.style.width = hpPct + '%';
    this.dom.mpFill.style.width = mpPct + '%';
    this.dom.hpLabel.textContent = `${Math.ceil(this.hp)} / ${Math.round(this.maxHp)}`;
    this.dom.mpLabel.textContent = `${Math.ceil(this.mp)} / ${Math.round(this.maxMp)}`;
    const xpPct = (this.stats.xp / this.stats.xpNext) * 100;
    this.dom.xpFill.style.width = xpPct + '%';
    this.dom.xpText.textContent = `XP ${Math.floor(this.stats.xp)} / ${this.stats.xpNext}`;
  }

  /* ---------------- 浮动战斗文字 ---------------- */
  floatText(worldPos, value, kind, isCrit) {
    const v = worldPos.clone(); v.project(this.camera);
    if (v.z > 1) return;   // 在相机背后
    const x = (v.x * 0.5 + 0.5) * innerWidth;
    const y = (-v.y * 0.5 + 0.5) * innerHeight;
    const el = document.createElement('div');
    el.className = 'float-text' + (isCrit ? ' crit' : '');
    let color = '#ffffff';
    if (kind === 'player') { color = '#ff6a7a'; el.textContent = '-' + value; }
    else if (kind === 'crit') { color = '#ffd24d'; el.textContent = value + '!'; }
    else { color = '#ffe0e0'; el.textContent = value; }
    el.style.color = color;
    el.style.left = x + 'px';
    el.style.top = y + 'px';
    el.style.transform = 'translate(-50%,-50%)';
    this.dom.floating.appendChild(el);
    setTimeout(() => el.remove(), 1000);
  }

  toast(msg) {
    this.dom.toast.textContent = msg;
    this.dom.toast.classList.add('show');
    clearTimeout(this._toastT);
    this._toastT = setTimeout(() => this.dom.toast.classList.remove('show'), 2000);
  }

  /* ============================================================
     11. 背包 / 圣物 UI
  ============================================================ */
  toggleInventory() {
    const inv = this.dom.inventory;
    inv.classList.toggle('open');
    if (inv.classList.contains('open')) {
      if (document.pointerLockElement) document.exitPointerLock();
      this.updateInventoryStats();
      this.renderPassiveGrid();
    }
  }

  updateInventoryStats() {
    document.getElementById('inv-hp').textContent = Math.round(this.maxHp);
    document.getElementById('inv-mp').textContent = Math.round(this.maxMp);
    document.getElementById('inv-atk').textContent = Math.round(this.atk);
    document.getElementById('inv-spd').textContent = this.speed.toFixed(1);
    document.getElementById('inv-crit').textContent = Math.round(this.crit * 100) + '%';
    document.getElementById('inv-misc').textContent =
      Math.round(this.stats.lifesteal * 100) + '% / ' + Math.round(this.stats.manaDiscount * 100) + '%';
  }

  renderPassiveGrid() {
    const grid = this.dom.passiveGrid;
    grid.innerHTML = '';
    // 每种圣物一个格子（有数量的显示，其余显示空格）
    const owned = RELIC_KEYS.filter(k => this.relicCounts[k] > 0);
    const totalSlots = 18;
    for (let i = 0; i < totalSlots; i++) {
      const cell = document.createElement('div');
      cell.className = 'inv-slot';
      if (i < owned.length) {
        const key = owned[i];
        const r = RELICS[key];
        cell.classList.add('filled');
        cell.innerHTML = `${r.icon}<span class="stack">${this.relicCounts[key]}</span>`;
        cell.addEventListener('mouseenter', (e) => this.showTooltip(e, r, this.relicCounts[key]));
        cell.addEventListener('mousemove', (e) => this.moveTooltip(e));
        cell.addEventListener('mouseleave', () => this.hideTooltip());
      }
      grid.appendChild(cell);
    }
  }

  showTooltip(e, relic, count) {
    const tt = this.dom.tooltip;
    tt.querySelector('.t-name').textContent = `${relic.icon} ${relic.name}`;
    tt.querySelector('.t-desc').textContent = relic.desc;
    tt.querySelector('.t-count').textContent = `持有数量: ${count}`;
    tt.style.display = 'block';
    this.moveTooltip(e);
  }
  moveTooltip(e) {
    const tt = this.dom.tooltip;
    tt.style.left = (e.clientX + 16) + 'px';
    tt.style.top = (e.clientY + 16) + 'px';
  }
  hideTooltip() { this.dom.tooltip.style.display = 'none'; }
}

// ---- 启动 ----
window.addEventListener('DOMContentLoaded', () => {
  try {
    window.__game = new Game();
  } catch (err) {
    document.getElementById('loading').innerHTML = '<div style="color:#ff6a7a;padding:40px;text-align:center">加载失败：' + err.message + '</div>';
    console.error(err);
  }
});
</script>
