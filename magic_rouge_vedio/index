<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>遗迹回响 · Echoes of the Ruined Sanctuary</title>

<!-- ============================================================
  Three.js 通过 CDN 的 ES Module 导入映射加载（版本锁定 r0.185.1）
  这样单文件保持整洁可读，且是单文件 Three.js 项目的标准做法。
============================================================ -->
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.185.1/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.185.1/examples/jsm/"
  }
}
</script>

<style>
  /* ===================== 全局与字体 ===================== */
  :root {
    --hp: #ff4d5e;
    --hp-glow: #ff8a94;
    --mp: #4db6ff;
    --mp-glow: #8fd4ff;
    --xp: #ffd24d;
    --arcane: #b98cff;
    --arcane-glow: #d9c2ff;
    --panel-bg: rgba(14, 10, 28, 0.82);
    --panel-border: rgba(150, 110, 255, 0.35);
    --text: #e8e2ff;
    --text-dim: #9a90c4;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    width: 100%; height: 100%;
    overflow: hidden;
    background: #05030d;
    color: var(--text);
    font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
    user-select: none;
    cursor: default;
  }

  canvas { display: block; }

  /* ===================== 通用面板样式 ===================== */
  .panel {
    background: var(--panel-bg);
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 40px rgba(80, 40, 160, 0.35),
                inset 0 0 24px rgba(120, 80, 200, 0.08);
  }

  /* ===================== HUD 容器 ===================== */
  #hud {
    position: fixed; inset: 0;
    pointer-events: none;
    z-index: 10;
  }
  #hud.hidden { display: none; }

  /* ---- 左上角：等级 + HP/MP ---- */
  #vitals {
    position: absolute; top: 18px; left: 18px;
    width: 320px;
    padding: 14px 16px;
    pointer-events: none;
  }
  .level-row {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 10px;
  }
  #level-badge {
    display: flex; align-items: center; justify-content: center;
    width: 46px; height: 46px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #7b53d6, #2a1a52);
    border: 2px solid var(--arcane-glow);
    box-shadow: 0 0 18px rgba(185, 140, 255, 0.6);
    font-size: 22px; font-weight: 700;
    color: #fff; text-shadow: 0 0 8px var(--arcane-glow);
  }
  .level-meta { flex: 1; }
  .level-meta .name { font-size: 14px; letter-spacing: 1px; color: var(--arcane-glow); }
  .level-meta .sub { font-size: 11px; color: var(--text-dim); }

  .bar {
    position: relative;
    height: 20px;
    border-radius: 10px;
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.12);
    overflow: hidden;
    margin-bottom: 8px;
  }
  .bar .fill {
    position: absolute; inset: 0;
    width: 100%;
    transform-origin: left;
    border-radius: 10px;
    transition: width 0.25s ease;
  }
  .bar .label {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 600;
    text-shadow: 0 1px 2px rgba(0,0,0,0.9);
    letter-spacing: 0.5px;
  }
  #hp-fill { background: linear-gradient(90deg, #8a1020, var(--hp) 60%, var(--hp-glow)); box-shadow: 0 0 12px var(--hp); }
  #mp-fill { background: linear-gradient(90deg, #1a4a8a, var(--mp) 60%, var(--mp-glow)); box-shadow: 0 0 12px var(--mp); }

  /* ---- 右上角：波次 + 状态 ---- */
  #wave-info {
    position: absolute; top: 18px; right: 18px;
    padding: 12px 18px;
    text-align: right;
    min-width: 180px;
  }
  #wave-info .wave-num { font-size: 30px; font-weight: 800; color: var(--arcane-glow); text-shadow: 0 0 14px var(--arcane); }
  #wave-info .wave-label { font-size: 11px; color: var(--text-dim); letter-spacing: 2px; text-transform: uppercase; }
  #wave-info .enemy-count { font-size: 13px; margin-top: 6px; color: var(--hp-glow); }
  #wave-info .timer { font-size: 12px; margin-top: 2px; color: var(--text-dim); }

  /* ---- 顶部中央：属性快览 ---- */
  #stats-quick {
    position: absolute; top: 18px; left: 50%; transform: translateX(-50%);
    display: flex; gap: 18px;
    padding: 8px 20px;
    font-size: 12px;
  }
  #stats-quick .stat { text-align: center; }
  #stats-quick .stat .v { font-size: 15px; font-weight: 700; color: var(--arcane-glow); }
  #stats-quick .stat .k { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }

  /* ---- 底部中央：XP 条 + 热键栏 ---- */
  #bottom-center {
    position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%);
    width: 560px;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
  }
  #xp-bar {
    width: 100%;
    height: 14px;
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 7px;
    overflow: hidden;
    position: relative;
  }
  #xp-fill {
    position: absolute; inset: 0; width: 0%;
    background: linear-gradient(90deg, #b58600, var(--xp) 70%, #fff2b8);
    box-shadow: 0 0 10px var(--xp);
    border-radius: 7px;
    transition: width 0.3s ease;
  }
  #xp-text {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 600; color: #fff; text-shadow: 0 1px 2px #000;
  }

  #hotbar { display: flex; gap: 10px; }
  .slot {
    position: relative;
    width: 62px; height: 62px;
    border-radius: 10px;
    background: rgba(20,14,40,0.85);
    border: 2px solid rgba(150,110,255,0.4);
    display: flex; align-items: center; justify-content: center;
    font-size: 30px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.5);
    transition: transform 0.08s, border-color 0.2s;
    pointer-events: auto; cursor: pointer;
  }
  .slot:hover { transform: translateY(-3px); border-color: var(--arcane-glow); }
  .slot .key {
    position: absolute; top: 2px; left: 5px;
    font-size: 11px; color: var(--text-dim); font-weight: 700;
  }
  .slot .cd-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.7);
    border-radius: 8px;
    transform-origin: bottom;
    transform: scaleY(0);
    pointer-events: none;
  }
  .slot .cost {
    position: absolute; bottom: 2px; right: 5px;
    font-size: 10px; color: var(--mp-glow); font-weight: 700;
  }
  .slot.no-mana { border-color: rgba(255,80,80,0.5); }

  /* ---- 左下角：亮度滑块 ---- */
  #brightness-ctl {
    position: absolute; bottom: 18px; left: 18px;
    padding: 12px 16px;
    pointer-events: auto;
    width: 220px;
  }
  #brightness-ctl label { font-size: 11px; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px; }
  #brightness-ctl .row { display: flex; align-items: center; gap: 10px; }
  #brightness-ctl input[type=range] {
    flex: 1; -webkit-appearance: none; appearance: none;
    height: 6px; border-radius: 3px;
    background: linear-gradient(90deg, #2a1a52, var(--arcane-glow));
    outline: none; cursor: pointer;
  }
  #brightness-ctl input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 16px; height: 16px; border-radius: 50%;
    background: #fff; box-shadow: 0 0 10px var(--arcane-glow);
    cursor: pointer;
  }
  #brightness-ctl input[type=range]::-moz-range-thumb {
    width: 16px; height: 16px; border-radius: 50%; border: none;
    background: #fff; box-shadow: 0 0 10px var(--arcane-glow); cursor: pointer;
  }
  #brightness-val { font-size: 12px; color: var(--arcane-glow); width: 34px; text-align: right; }

  /* ---- 准星 ---- */
  #crosshair {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 22px; height: 22px; pointer-events: none;
    opacity: 0.7;
  }
  #crosshair::before, #crosshair::after {
    content: ""; position: absolute; background: var(--arcane-glow);
    box-shadow: 0 0 6px var(--arcane);
  }
  #crosshair::before { left: 50%; top: 0; width: 2px; height: 100%; transform: translateX(-50%); }
  #crosshair::after { top: 50%; left: 0; height: 2px; width: 100%; transform: translateY(-50%); }

  /* ===================== 浮动战斗文字 ===================== */
  #floating-layer { position: fixed; inset: 0; pointer-events: none; z-index: 15; overflow: hidden; }
  .float-text {
    position: absolute;
    font-weight: 800;
    font-size: 20px;
    text-shadow: 0 2px 4px rgba(0,0,0,0.9);
    animation: floatUp 1s ease-out forwards;
    white-space: nowrap;
  }
  .float-text.crit { font-size: 30px; }
  @keyframes floatUp {
    0%   { transform: translateY(0) scale(0.6); opacity: 0; }
    15%  { transform: translateY(-8px) scale(1.15); opacity: 1; }
    30%  { transform: translateY(-16px) scale(1); }
    100% { transform: translateY(-70px) scale(0.9); opacity: 0; }
  }

  /* ===================== 库存面板（按 I） ===================== */
  #inventory {
    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 640px; max-height: 78vh;
    padding: 24px;
    z-index: 30;
    display: none;
    flex-direction: column;
    pointer-events: auto;
  }
  #inventory.open { display: flex; }
  #inventory h2 { font-size: 20px; color: var(--arcane-glow); margin-bottom: 4px; letter-spacing: 2px; }
  #inventory .hint { font-size: 11px; color: var(--text-dim); margin-bottom: 18px; }
  #inventory .section-title { font-size: 13px; color: var(--arcane-glow); text-transform: uppercase; letter-spacing: 1.5px; margin: 16px 0 10px; border-bottom: 1px solid var(--panel-border); padding-bottom: 6px; }

  .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .stat-cell { background: rgba(0,0,0,0.3); border-radius: 8px; padding: 10px; text-align: center; }
  .stat-cell .k { font-size: 10px; color: var(--text-dim); text-transform: uppercase; }
  .stat-cell .v { font-size: 18px; font-weight: 700; color: var(--arcane-glow); margin-top: 3px; }

  .item-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; }
  .inv-slot {
    aspect-ratio: 1;
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(150,110,255,0.25);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px;
    position: relative; cursor: help;
    transition: transform 0.1s, border-color 0.2s;
  }
  .inv-slot.filled:hover { transform: scale(1.08); border-color: var(--arcane-glow); box-shadow: 0 0 14px rgba(185,140,255,0.5); }
  .inv-slot .stack {
    position: absolute; bottom: 2px; right: 4px;
    font-size: 11px; font-weight: 700; color: #fff; text-shadow: 0 1px 2px #000;
  }

  /* 工具提示 */
  #tooltip {
    position: fixed; z-index: 60;
    max-width: 240px; padding: 10px 12px;
    background: rgba(8,5,20,0.96);
    border: 1px solid var(--arcane); border-radius: 8px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.6);
    font-size: 12px; pointer-events: none; display: none;
  }
  #tooltip .t-name { font-size: 13px; font-weight: 700; color: var(--arcane-glow); margin-bottom: 4px; }
  #tooltip .t-desc { color: var(--text); line-height: 1.5; }
  #tooltip .t-count { color: var(--xp); margin-top: 6px; font-size: 11px; }

  /* ===================== 屏幕遮罩（菜单 / 结束） ===================== */
  .overlay {
    position: fixed; inset: 0; z-index: 50;
    display: flex; align-items: center; justify-content: center;
    background: radial-gradient(circle at 50% 40%, rgba(40,20,80,0.6), rgba(3,2,10,0.94));
    backdrop-filter: blur(4px);
  }
  .overlay.hidden { display: none; }

  .menu-box { width: 480px; padding: 44px 40px; text-align: center; pointer-events: auto; }
  .menu-box .title {
    font-size: 38px; font-weight: 800; letter-spacing: 3px;
    background: linear-gradient(90deg, var(--arcane-glow), var(--mp-glow), var(--arcane-glow));
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    text-shadow: 0 0 40px rgba(185,140,255,0.4);
    margin-bottom: 6px;
  }
  .menu-box .subtitle { font-size: 13px; color: var(--text-dim); letter-spacing: 4px; text-transform: uppercase; margin-bottom: 34px; }

  .btn {
    display: block; width: 100%;
    padding: 14px; margin: 12px 0;
    font-size: 16px; font-weight: 600; letter-spacing: 1px;
    color: var(--text);
    background: linear-gradient(135deg, rgba(90,55,170,0.6), rgba(40,25,80,0.6));
    border: 1px solid var(--arcane); border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn:hover:not(:disabled) { background: linear-gradient(135deg, rgba(130,85,220,0.85), rgba(70,40,130,0.85)); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(120,70,220,0.4); }
  .btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .btn.danger { border-color: var(--hp); }
  .btn.danger:hover { background: linear-gradient(135deg, rgba(200,50,70,0.85), rgba(100,20,40,0.85)); box-shadow: 0 8px 24px rgba(220,60,80,0.4); }

  .save-preview {
    margin-top: 8px; margin-bottom: 20px;
    font-size: 12px; color: var(--text-dim); line-height: 1.7;
    padding: 12px; background: rgba(0,0,0,0.3); border-radius: 8px;
  }
  .save-preview.none { color: #64597f; font-style: italic; }
  .save-preview b { color: var(--arcane-glow); font-weight: 700; }

  /* 结束画面统计 */
  .gameover-stats { margin: 20px 0 26px; }
  .gameover-stats .row {
    display: flex; justify-content: space-between;
    padding: 8px 4px; border-bottom: 1px solid rgba(150,110,255,0.15);
    font-size: 14px;
  }
  .gameover-stats .row .k { color: var(--text-dim); }
  .gameover-stats .row .v { color: var(--arcane-glow); font-weight: 700; }
  #gameover .title { color: var(--hp); background: none; -webkit-text-fill-color: var(--hp); text-shadow: 0 0 30px rgba(255,77,94,0.6); }

  /* ---- 顶部 toast / 提示 ---- */
  #toast {
    position: fixed; top: 90px; left: 50%; transform: translateX(-50%);
    padding: 12px 26px; z-index: 40;
    font-size: 15px; font-weight: 600; color: var(--arcane-glow);
    opacity: 0; transition: opacity 0.4s, transform 0.4s;
    pointer-events: none;
    text-align: center;
  }
  #toast.show { opacity: 1; transform: translateX(-50%) translateY(6px); }

  /* 波次开场大字 */
  #wave-banner {
    position: fixed; top: 40%; left: 50%; transform: translate(-50%,-50%);
    z-index: 40; text-align: center; pointer-events: none;
    opacity: 0;
  }
  #wave-banner.show { animation: bannerPop 2.4s ease-out forwards; }
  #wave-banner .big { font-size: 52px; font-weight: 800; color: var(--arcane-glow); text-shadow: 0 0 30px var(--arcane); letter-spacing: 4px; }
  #wave-banner .small { font-size: 16px; color: var(--text-dim); letter-spacing: 3px; text-transform: uppercase; }
  @keyframes bannerPop {
    0% { opacity: 0; transform: translate(-50%,-50%) scale(0.7); }
    15% { opacity: 1; transform: translate(-50%,-50%) scale(1); }
    80% { opacity: 1; }
    100% { opacity: 0; transform: translate(-50%,-50%) scale(1.05); }
  }

  #loading {
    position: fixed; inset: 0; z-index: 100;
    display: flex; align-items: center; justify-content: center; flex-direction: column;
    background: #05030d; color: var(--arcane-glow);
    font-size: 18px; letter-spacing: 3px;
  }
  #loading .spinner {
    width: 44px; height: 44px; margin-bottom: 20px;
    border: 3px solid rgba(185,140,255,0.2);
    border-top-color: var(--arcane-glow);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  #loading.hidden { display: none; }

  .controls-hint {
    position: absolute; bottom: 100px; left: 50%; transform: translateX(-50%);
    font-size: 11px; color: var(--text-dim); letter-spacing: 1px;
    text-align: center; line-height: 1.6; pointer-events: none;
  }
</style>
</head>
<body>

<!-- 加载画面 -->
<div id="loading"><div class="spinner"></div><div>正在唤醒远古圣所…</div></div>

<!-- ===================== 游戏 HUD ===================== -->
<div id="hud" class="hidden">
  <!-- 左上：等级 + 生命 + 法力 -->
  <div id="vitals" class="panel">
    <div class="level-row">
      <div id="level-badge">1</div>
      <div class="level-meta">
        <div class="name">流浪法师</div>
        <div class="sub">Arcane Wanderer</div>
      </div>
    </div>
    <div class="bar"><div class="fill" id="hp-fill"></div><div class="label" id="hp-label">100 / 100</div></div>
    <div class="bar"><div class="fill" id="mp-fill"></div><div class="label" id="mp-label">100 / 100</div></div>
  </div>

  <!-- 顶部中央：属性快览 -->
  <div id="stats-quick" class="panel">
    <div class="stat"><div class="v" id="stat-atk">10</div><div class="k">攻击</div></div>
    <div class="stat"><div class="v" id="stat-spd">6.0</div><div class="k">移速</div></div>
    <div class="stat"><div class="v" id="stat-crit">10%</div><div class="k">暴击</div></div>
  </div>

  <!-- 右上：波次信息 -->
  <div id="wave-info" class="panel">
    <div class="wave-num" id="wave-num">1</div>
    <div class="wave-label">波次 / WAVE</div>
    <div class="enemy-count" id="enemy-count">敌人: 0</div>
    <div class="timer" id="wave-timer"></div>
  </div>

  <!-- 底部中央：XP + 热键栏 -->
  <div id="bottom-center">
    <div id="hotbar">
      <div class="slot" data-skill="0"><span class="key">1</span>🔥<span class="cost">10</span><div class="cd-overlay"></div></div>
      <div class="slot" data-skill="1"><span class="key">2</span>❄️<span class="cost">25</span><div class="cd-overlay"></div></div>
      <div class="slot" data-skill="2"><span class="key">3</span>⚡<span class="cost">20</span><div class="cd-overlay"></div></div>
    </div>
    <div id="xp-bar"><div id="xp-fill"></div><div id="xp-text">XP 0 / 100</div></div>
  </div>

  <!-- 左下：亮度滑块 -->
  <div id="brightness-ctl" class="panel">
    <label>环境亮度 / Brightness</label>
    <div class="row">
      <input type="range" id="brightness" min="20" max="200" value="100" />
      <span id="brightness-val">100</span>
    </div>
  </div>

  <!-- 准星 -->
  <div id="crosshair"></div>

  <div class="controls-hint" id="controls-hint">WASD 移动 · 鼠标 视角 · 左键/1 火球 · 2 冰冻 · 3 闪电冲刺 · I 背包 · 点击锁定鼠标</div>
</div>

<!-- 浮动战斗文字层 -->
<div id="floating-layer"></div>

<!-- 波次横幅 -->
<div id="wave-banner"><div class="big" id="banner-big">第 1 波</div><div class="small" id="banner-small">敌人来袭</div></div>

<!-- toast -->
<div id="toast" class="panel"></div>

<!-- ===================== 库存面板 ===================== -->
<div id="inventory" class="panel">
  <h2>背包与能力 · Grimoire</h2>
  <div class="hint">按 I 关闭 · 悬停查看词条说明</div>

  <div class="section-title">角色属性</div>
  <div class="stat-grid">
    <div class="stat-cell"><div class="k">最大生命</div><div class="v" id="inv-hp">100</div></div>
    <div class="stat-cell"><div class="k">最大法力</div><div class="v" id="inv-mp">100</div></div>
    <div class="stat-cell"><div class="k">攻击强度</div><div class="v" id="inv-atk">10</div></div>
    <div class="stat-cell"><div class="k">移动速度</div><div class="v" id="inv-spd">6.0</div></div>
    <div class="stat-cell"><div class="k">暴击几率</div><div class="v" id="inv-crit">10%</div></div>
    <div class="stat-cell"><div class="k">吸血 / 法力折扣</div><div class="v" id="inv-misc">0% / 0%</div></div>
  </div>

  <div class="section-title">被动圣物 · Passive Relics</div>
  <div class="item-grid" id="passive-grid"></div>
</div>

<!-- 物品工具提示 -->
<div id="tooltip"><div class="t-name"></div><div class="t-desc"></div><div class="t-count"></div></div>

<!-- ===================== 主菜单 ===================== -->
<div id="main-menu" class="overlay hidden">
  <div class="menu-box panel">
    <div class="title">遗迹回响</div>
    <div class="subtitle">Echoes of the Ruined Sanctuary</div>
    <div class="save-preview none" id="save-preview">暂无存档</div>
    <button class="btn" id="btn-continue" disabled>继续征程 · Continue Run</button>
    <button class="btn" id="btn-new">全新征程 · New Run</button>
  </div>
</div>

