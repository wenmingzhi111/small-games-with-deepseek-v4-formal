/* ============================================================
   1. 音频引擎（Web Audio API 合成，无外部资源）
============================================================ */
class AudioEngine {
  constructor() {
    this.ctx = null;
    this.master = null;
    this.droneNodes = null;
    this.enabled = true;
  }
  // 需在用户手势后初始化（浏览器自动播放策略）
  init() {
    if (this.ctx) return;
    const AC = window.AudioContext || window.webkitAudioContext;
    this.ctx = new AC();
    this.master = this.ctx.createGain();
    this.master.gain.value = 0.5;
    this.master.connect(this.ctx.destination);
  }
  resume() { if (this.ctx && this.ctx.state === 'suspended') this.ctx.resume(); }

  // 低沉诡异的环境嗡鸣（两个失谐振荡器 + 缓慢 LFO）
  startDrone() {
    if (!this.ctx || this.droneNodes) return;
    const g = this.ctx.createGain();
    g.gain.value = 0.0;
    g.connect(this.master);
    g.gain.linearRampToValueAtTime(0.16, this.ctx.currentTime + 3);

    const o1 = this.ctx.createOscillator(); o1.type = 'sine'; o1.frequency.value = 55;
    const o2 = this.ctx.createOscillator(); o2.type = 'sine'; o2.frequency.value = 55.4;
    const o3 = this.ctx.createOscillator(); o3.type = 'triangle'; o3.frequency.value = 110;
    const o3g = this.ctx.createGain(); o3g.gain.value = 0.04;

    const filt = this.ctx.createBiquadFilter(); filt.type = 'lowpass'; filt.frequency.value = 400;

    // 缓慢起伏的 LFO 调制音量，营造呼吸感
    const lfo = this.ctx.createOscillator(); lfo.type = 'sine'; lfo.frequency.value = 0.08;
    const lfoG = this.ctx.createGain(); lfoG.gain.value = 0.05;
    lfo.connect(lfoG); lfoG.connect(g.gain);

    o1.connect(filt); o2.connect(filt); o3.connect(o3g); o3g.connect(filt);
    filt.connect(g);
    o1.start(); o2.start(); o3.start(); lfo.start();
    this.droneNodes = { o1, o2, o3, lfo, g };
  }

  // 通用合成音效
  _blip(type, freq, dur, vol, sweepTo, curve = 'exp') {
    if (!this.ctx || !this.enabled) return;
    const t = this.ctx.currentTime;
    const o = this.ctx.createOscillator();
    const g = this.ctx.createGain();
    o.type = type; o.frequency.setValueAtTime(freq, t);
    if (sweepTo) {
      if (curve === 'exp') o.frequency.exponentialRampToValueAtTime(Math.max(1, sweepTo), t + dur);
      else o.frequency.linearRampToValueAtTime(sweepTo, t + dur);
    }
    g.gain.setValueAtTime(0.0001, t);
    g.gain.exponentialRampToValueAtTime(vol, t + 0.01);
    g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
    o.connect(g); g.connect(this.master);
    o.start(t); o.stop(t + dur + 0.02);
  }
  _noise(dur, vol, filterFreq) {
    if (!this.ctx || !this.enabled) return;
    const t = this.ctx.currentTime;
    const buf = this.ctx.createBuffer(1, this.ctx.sampleRate * dur, this.ctx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * (1 - i / data.length);
    const src = this.ctx.createBufferSource(); src.buffer = buf;
    const filt = this.ctx.createBiquadFilter(); filt.type = 'lowpass'; filt.frequency.value = filterFreq;
    const g = this.ctx.createGain(); g.gain.value = vol;
    src.connect(filt); filt.connect(g); g.connect(this.master);
    src.start(t);
  }

  cast(skillId) {
    if (skillId === 'fireball') this._blip('sawtooth', 320, 0.22, 0.18, 120);
    else if (skillId === 'frost') { this._blip('triangle', 900, 0.5, 0.16, 300, 'lin'); this._noise(0.4, 0.06, 2000); }
    else if (skillId === 'dash') this._blip('square', 180, 0.3, 0.16, 1200);
  }
  impact() { this._noise(0.18, 0.14, 900); this._blip('sine', 140, 0.14, 0.1, 60); }
  hurt() { this._blip('sawtooth', 220, 0.25, 0.2, 80, 'lin'); this._noise(0.15, 0.1, 500); }
  pickup() { this._blip('sine', 660, 0.12, 0.12, 990); }
  levelup() {
    // 上扬的欢快琶音
    [523, 659, 784, 1047].forEach((f, i) => setTimeout(() => this._blip('triangle', f, 0.28, 0.16, f * 1.02), i * 90));
  }
  enemyDie() { this._blip('sawtooth', 160, 0.3, 0.14, 40, 'lin'); this._noise(0.25, 0.08, 700); }
  waveStart() { [392, 523].forEach((f, i) => setTimeout(() => this._blip('square', f, 0.35, 0.12, f), i * 140)); }
}

/* ============================================================
